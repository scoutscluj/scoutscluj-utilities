{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "pnpm railway:build:api",
    "watchPatterns": [
      "apps/api/**",
      "packages/**",
      "package.json",
      "pnpm-lock.yaml",
      "pnpm-workspace.yaml",
      "turbo.json",
      "railway.api.json"
    ]
  },
  "deploy": {
    "preDeployCommand": "pnpm railway:migrate:api",
    "startCommand": "pnpm railway:start:api",
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
